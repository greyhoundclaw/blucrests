PORT=4000
DB_PROVIDER=sqlite
SQLITE_DB_PATH=local.db
# For Railway later, set DB_PROVIDER=postgres and provide DATABASE_URL.
# DATABASE_URL=postgres://user:password@host:5432/bluecrest
NODE_ENV=development
# Sandbox overrides are disabled by default when NODE_ENV=production.
SANDBOX_ENABLED=false

# Used to encrypt SMTP passwords stored by the admin email settings screen.
# Set a long, stable secret in every deployed environment.
SMTP_ENCRYPTION_KEY=replace-with-a-long-random-secret

COMPANY_NAME=Blue Crest Premium Banking
COMPANY_TAGLINE=Secure international financial services

# Public Bitcoin receiving address shown to approved card applicants.
BITCOIN_PAYMENT_ADDRESS=

# Receives an email copy when a user submits a card Txn Reference.
CARD_REFERENCE_SUPPORT_EMAIL=bluecrestsupport@gmail.com

# Optional environment fallback when no SMTP settings are stored in the database.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true
MAIL_FROM=
MAIL_FROM_NAME=Blue Crest

# Preferred on Railway Free/Trial/Hobby because it uses HTTPS instead of blocked SMTP ports.
# Create a Zoho OAuth Self Client with ZohoMail.accounts.READ,ZohoMail.messages.CREATE.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNT_ID=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_MAIL_API_URL=https://mail.zoho.com
