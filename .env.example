PORT=3000
BACKEND_URL=http://localhost:4000
DISABLE_HMR=false

# Public Bitcoin receiving address shown after a card application is approved.
BITCOIN_PAYMENT_ADDRESS=

# Receives an email copy when a user submits a card Txn Reference.
CARD_REFERENCE_SUPPORT_EMAIL=bluecrestsupport@gmail.com

# Gmail SMTP used by the internal backend for verification and account alerts.
# Set these values as Railway service variables; never commit the real password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true
MAIL_FROM=
MAIL_FROM_NAME=Blue Crest Support
SMTP_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Preferred on Railway Free/Trial/Hobby because it uses HTTPS instead of blocked SMTP ports.
# Create a Zoho OAuth Self Client with ZohoMail.accounts.READ,ZohoMail.messages.CREATE.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNT_ID=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_MAIL_API_URL=https://mail.zoho.com
